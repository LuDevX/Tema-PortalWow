<style>
/* ── NAV ─────────────────────────────────────────── */
#pw-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 68px; padding: 0 5vw;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(8,10,13,0.75);
  backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--pw-border);
  transition: background 0.3s, border-color 0.3s;
}
#pw-nav.pw-nav--scrolled {
  background: rgba(8,10,13,0.95);
  border-color: var(--pw-border2);
}
.pw-nav-logo {
  display: flex; align-items: center; gap: 10px; flex-shrink: 0;
}
.pw-nav-logo img { height: 38px; width: auto; }
.pw-nav-logo-text {
  font-family: var(--pw-font-display); font-size: 19px; font-weight: 800;
  color: var(--pw-text); letter-spacing: -0.5px;
}
.pw-nav-center {
  display: flex; align-items: center; gap: 6px;
}
.pw-nav-center a {
  font-size: 14px; color: var(--pw-muted); padding: 7px 14px;
  border-radius: 8px; transition: color 0.2s, background 0.2s;
  position: relative;
}
.pw-nav-center a:hover { color: var(--pw-text); background: var(--pw-surface); }
.pw-nav-center a.pw-active { color: var(--pw-green); }
.pw-nav-right { display: flex; align-items: center; gap: 12px; }
.pw-nav-cart {
  position: relative; display: flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; border-radius: 10px;
  border: 1px solid var(--pw-border2); color: var(--pw-muted);
  transition: border-color 0.2s, color 0.2s;
}
.pw-nav-cart:hover { border-color: var(--pw-green); color: var(--pw-green); }
.pw-cart-count {
  position: absolute; top: -5px; right: -5px;
  min-width: 18px; height: 18px; border-radius: 9px;
  background: var(--pw-green); color: #050807;
  font-size: 10px; font-weight: 800;
  display: none; align-items: center; justify-content: center;
  font-family: var(--pw-font-mono);
}
.pw-nav-cta {
  display: inline-flex; align-items: center; gap: 7px;
  background: var(--pw-green-dim); color: var(--pw-green);
  border: 1px solid rgba(0,229,160,0.25);
  font-size: 13px; font-weight: 600;
  padding: 8px 18px; border-radius: 100px;
  transition: background 0.2s, border-color 0.2s;
}
.pw-nav-cta:hover { background: rgba(0,229,160,0.15); border-color: var(--pw-green); color: var(--pw-green); }

/* Hamburger */
#pw-ham {
  display: none; flex-direction: column; gap: 5px;
  padding: 6px; border-radius: 8px;
  border: 1px solid var(--pw-border2);
  transition: border-color 0.2s;
}
#pw-ham:hover { border-color: var(--pw-border2); }
#pw-ham span {
  display: block; width: 20px; height: 1.5px;
  background: var(--pw-muted); border-radius: 1px;
  transition: transform 0.3s, opacity 0.3s;
}
#pw-ham[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
#pw-ham[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
#pw-ham[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* Nav overlay */
.pw-nav-overlay {
  display: none; position: fixed; inset: 0; z-index: 198;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
}
.pw-nav-overlay.pw-open { display: block; }

/* Mobile drawer */
#pw-nav-drawer {
  position: fixed; top: 68px; left: 0; right: 0; z-index: 199;
  background: var(--pw-bg2); border-bottom: 1px solid var(--pw-border);
  padding: 20px 5vw 28px;
  transform: translateY(-8px); opacity: 0; pointer-events: none;
  transition: transform 0.25s ease, opacity 0.25s ease;
}
#pw-nav-drawer.pw-open { transform: translateY(0); opacity: 1; pointer-events: auto; }
.pw-drawer-links { display: flex; flex-direction: column; gap: 4px; margin-bottom: 16px; }
.pw-drawer-links a {
  font-size: 16px; color: var(--pw-muted); padding: 10px 12px;
  border-radius: 10px; transition: color 0.2s, background 0.2s;
}
.pw-drawer-links a:hover { color: var(--pw-text); background: var(--pw-surface); }

/* Body offset for nav */
body { padding-top: 68px; }

@media (max-width: 768px) {
  .pw-nav-center { display: none; }
  #pw-ham { display: flex; }
  .pw-nav-cta span { display: none; }
}
</style>

<nav id="pw-nav" role="navigation" aria-label="Navegación principal">
  <a href="{{ routes.root_url }}" class="pw-nav-logo">
    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: height: 80 }}" alt="{{ shop.name }}" width="auto" height="40">
    {%- else -%}
      <span class="pw-nav-logo-text">{{ shop.name }}</span>
    {%- endif -%}
  </a>

  {%- assign page_descargas = pages['descargas'] -%}
  {%- assign page_soporte   = pages['soporte'] -%}
  {%- assign page_blogs     = pages['blogs'] -%}

  <div class="pw-nav-center">
    <a href="{{ routes.root_url }}" {% if template.name == 'index' %}class="pw-active"{% endif %}>Inicio</a>
    <a href="{{ routes.collections_url }}/all" {% if template.name == 'collection' %}class="pw-active"{% endif %}>Softwares</a>
    {%- if page_descargas != blank and page_descargas.published_at != blank -%}
      <a href="{{ routes.pages_url }}/descargas">Descargar gratis</a>
    {%- endif -%}
    {%- if page_soporte != blank and page_soporte.published_at != blank -%}
      <a href="{{ routes.pages_url }}/soporte">Soporte</a>
    {%- endif -%}
    {%- if page_blogs != blank and page_blogs.published_at != blank -%}
      <a href="/pages/blogs">Blog</a>
    {%- endif -%}
  </div>

  <div class="pw-nav-right">
    <a href="{{ routes.cart_url }}" class="pw-nav-cart" aria-label="Carrito">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M2 2h2l2 9h8l2-7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="8" cy="15" r="1" fill="currentColor"/>
        <circle cx="14" cy="15" r="1" fill="currentColor"/>
      </svg>
      <span class="pw-cart-count" aria-label="items en carrito">0</span>
    </a>
    {%- if page_descargas != blank and page_descargas.published_at != blank -%}
      <a href="{{ routes.pages_url }}/descargas" class="pw-nav-cta">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1v8M3 6.5l3.5 4 3.5-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M1 11h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        <span>Versión gratuita</span>
      </a>
    {%- endif -%}
    <button id="pw-ham" aria-label="Menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="pw-nav-drawer" aria-hidden="true">
  <div class="pw-drawer-links">
    <a href="{{ routes.root_url }}">Inicio</a>
    <a href="{{ routes.collections_url }}/all">Softwares</a>
    {%- if page_descargas != blank and page_descargas.published_at != blank -%}
      <a href="{{ routes.pages_url }}/descargas">Descargar gratis</a>
    {%- endif -%}
    {%- if page_soporte != blank and page_soporte.published_at != blank -%}
      <a href="{{ routes.pages_url }}/soporte">Soporte</a>
    {%- endif -%}
    {%- if page_blogs != blank and page_blogs.published_at != blank -%}
      <a href="/pages/blogs">Blog</a>
    {%- endif -%}
  </div>
  {%- if page_descargas != blank and page_descargas.published_at != blank -%}
    <a href="{{ routes.pages_url }}/descargas" class="pw-btn-primary" style="width:100%; justify-content:center;">
      📥 Descargar versión gratuita
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
