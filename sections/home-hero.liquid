<style>
/* ── HERO ─────────────────────────────────────────── */
.pw-hero {
  min-height: calc(100vh - 68px);
  display: flex; flex-direction: column; justify-content: center;
  padding: 72px 5vw 80px; position: relative; overflow: hidden;
}
.pw-hero-orb1 {
  position: absolute; top: -180px; right: -120px;
  width: 640px; height: 640px; pointer-events: none;
  background: radial-gradient(circle, rgba(0,229,160,0.065) 0%, transparent 65%);
}
.pw-hero-orb2 {
  position: absolute; bottom: -80px; left: -120px;
  width: 500px; height: 500px; pointer-events: none;
  background: radial-gradient(circle, rgba(139,92,246,0.05) 0%, transparent 65%);
}
.pw-hero-inner { max-width: 1160px; margin: 0 auto; width: 100%; position: relative; z-index: 1; }

.pw-hero-status {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1px solid var(--pw-border2); padding: 6px 16px; border-radius: 100px;
  font-family: var(--pw-font-mono); font-size: 12px; color: var(--pw-muted);
  margin-bottom: 28px;
}
.pw-hero h1 {
  font-size: clamp(42px, 7vw, 88px); font-weight: 800;
  line-height: 1.0; letter-spacing: -2px; margin-bottom: 10px;
}
.pw-hero h1 em { color: var(--pw-green); font-style: normal; }
.pw-hero-sub {
  font-family: var(--pw-font-display); font-size: clamp(16px, 2vw, 26px);
  font-weight: 700; color: var(--pw-muted2); letter-spacing: -0.2px;
  margin-bottom: 22px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
}
.pw-hero-sub-sep { width: 4px; height: 4px; background: var(--pw-muted2); border-radius: 50%; }
.pw-hero-desc {
  font-size: 17px; font-weight: 300; color: var(--pw-muted);
  line-height: 1.78; max-width: 520px; margin-bottom: 40px;
}
.pw-hero-actions { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 64px; }
.pw-hero-stats {
  display: flex; gap: 48px; padding-top: 28px;
  border-top: 1px solid var(--pw-border); flex-wrap: wrap;
}
.pw-stat strong {
  display: block; font-family: var(--pw-font-display);
  font-size: 34px; font-weight: 800; color: var(--pw-text);
  letter-spacing: -1.5px; line-height: 1; margin-bottom: 4px;
}
.pw-stat span {
  font-family: var(--pw-font-mono); font-size: 11px;
  color: var(--pw-muted2); text-transform: uppercase; letter-spacing: 0.5px;
}

/* ── MARQUEE ──────────────────────────────────────── */
.pw-marquee-wrap {
  border-top: 1px solid var(--pw-border); border-bottom: 1px solid var(--pw-border);
  padding: 14px 0; overflow: hidden; background: var(--pw-bg2);
  position: relative; z-index: 1;
}
.pw-marquee-track {
  display: flex; gap: 40px; width: max-content;
  animation: pw-marquee 32s linear infinite;
}
.pw-marquee-track:hover { animation-play-state: paused; }
@keyframes pw-marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.pw-marquee-item {
  display: flex; align-items: center; gap: 10px;
  font-family: var(--pw-font-mono); font-size: 12px; color: var(--pw-muted2); white-space: nowrap;
}
.pw-marquee-item .g { color: var(--pw-green); }
.pw-marquee-sep { width: 3px; height: 3px; background: var(--pw-muted2); border-radius: 50%; }

/* ── PRODUCTO DESTACADO ───────────────────────────── */
.pw-product-hero {
  display: grid; grid-template-columns: 1.1fr 0.9fr;
  border: 1px solid var(--pw-border); border-radius: var(--pw-radius-lg);
  overflow: hidden; margin-bottom: 20px;
}
.pw-ph-left {
  background: var(--pw-bg3); padding: 52px 48px;
  display: flex; flex-direction: column; justify-content: space-between; min-height: 420px;
}
.pw-ph-right {
  background: var(--pw-surface); padding: 40px;
  display: flex; flex-direction: column; justify-content: center; gap: 10px;
  position: relative; overflow: hidden;
}
.pw-ph-right::before {
  content: ''; position: absolute; top: -80px; right: -80px;
  width: 240px; height: 240px;
  background: radial-gradient(circle, rgba(0,229,160,0.07) 0%, transparent 70%);
}
.pw-ph-left h3 {
  font-size: clamp(24px, 3.5vw, 42px); font-weight: 800; letter-spacing: -1px;
  color: var(--pw-text); line-height: 1.05; margin-bottom: 10px;
}
.pw-ph-left > div > p {
  font-size: 14px; font-weight: 300; color: var(--pw-muted); line-height: 1.75; margin-bottom: 24px;
}
.pw-ph-price { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
.pw-ph-price .pw-price-now { font-size: 38px; }
.pw-ph-btns { display: flex; gap: 10px; flex-wrap: wrap; }

/* Flow mini */
.pw-flow { display: flex; flex-direction: column; gap: 6px; }
.pw-flow-step {
  display: flex; align-items: center; gap: 12px;
  background: var(--pw-bg3); border: 1px solid var(--pw-border);
  border-radius: 10px; padding: 10px 14px;
}
.pw-flow-icon { font-size: 18px; flex-shrink: 0; }
.pw-flow-name { font-size: 12px; font-weight: 600; color: var(--pw-text); margin-bottom: 1px; }
.pw-flow-meta { font-family: var(--pw-font-mono); font-size: 10px; color: var(--pw-muted2); }
.pw-flow-arr { text-align: center; color: var(--pw-muted2); font-size: 14px; padding: 2px; }
.pw-flow-result {
  display: flex; align-items: center; gap: 12px;
  background: var(--pw-green-dim); border: 1px solid rgba(0,229,160,0.2);
  border-radius: 10px; padding: 10px 14px;
}
.pw-flow-result-name { font-size: 12px; font-weight: 600; color: var(--pw-green); margin-bottom: 1px; }
.pw-flow-result-meta { font-family: var(--pw-font-mono); font-size: 10px; color: rgba(0,229,160,0.45); }

/* Coming soon */
.pw-coming-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
}
.pw-coming {
  border: 1px dashed var(--pw-border2); border-radius: var(--pw-radius);
  padding: 28px 24px; position: relative; overflow: hidden;
  transition: border-color 0.25s;
}
.pw-coming:hover { border-color: rgba(0,229,160,0.2); }
.pw-coming-label {
  position: absolute; top: 16px; right: 16px;
  font-family: var(--pw-font-mono); font-size: 9px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1px; color: var(--pw-muted2);
  border: 1px solid var(--pw-border2); padding: 2px 8px; border-radius: 100px;
}
.pw-coming-icon { font-size: 34px; display: block; margin-bottom: 12px; }
.pw-coming h4 {
  font-family: var(--pw-font-display); font-size: 16px; font-weight: 700;
  color: var(--pw-muted); letter-spacing: -0.3px; margin-bottom: 6px;
}
.pw-coming p { font-size: 13px; font-weight: 300; color: var(--pw-muted2); line-height: 1.65; }

/* ── CASOS DE USO ─────────────────────────────────── */
.pw-use-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
  max-width: 1160px; margin: 0 auto;
}
.pw-use {
  background: var(--pw-bg3); border: 1px solid var(--pw-border);
  border-radius: var(--pw-radius); padding: 28px 22px;
  transition: border-color 0.25s, transform 0.25s;
}
.pw-use:hover { border-color: rgba(0,229,160,0.22); transform: translateY(-3px); }
.pw-use-num { font-family: var(--pw-font-mono); font-size: 10px; color: var(--pw-muted2); margin-bottom: 12px; }
.pw-use-icon { font-size: 30px; display: block; margin-bottom: 12px; }
.pw-use h4 {
  font-family: var(--pw-font-display); font-size: 15px; font-weight: 700;
  color: var(--pw-text); margin-bottom: 6px; letter-spacing: -0.3px;
}
.pw-use p { font-size: 13px; font-weight: 300; color: var(--pw-muted); line-height: 1.65; }

/* ── ABOUT / MANIFIESTO ───────────────────────────── */
.pw-about {
  display: grid; grid-template-columns: 1fr 1fr; gap: 72px;
  align-items: center; max-width: 1160px; margin: 0 auto;
}
.pw-about-left h2 {
  font-size: clamp(30px, 4.5vw, 54px); letter-spacing: -2px; margin-bottom: 18px;
}
.pw-about-left h2 em { color: var(--pw-green); font-style: normal; }
.pw-about-left p {
  font-size: 15px; font-weight: 300; color: var(--pw-muted);
  line-height: 1.8; margin-bottom: 14px;
}
.pw-manifesto { display: flex; flex-direction: column; gap: 18px; }
.pw-manifesto-item { display: flex; gap: 16px; align-items: flex-start; }
.pw-manifesto-n {
  font-family: var(--pw-font-mono); font-size: 10px; color: var(--pw-green);
  background: var(--pw-green-dim); border: 1px solid rgba(0,229,160,0.15);
  width: 30px; height: 30px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;
}
.pw-manifesto-item h4 {
  font-family: var(--pw-font-display); font-size: 15px; font-weight: 700;
  color: var(--pw-text); margin-bottom: 4px; letter-spacing: -0.3px;
}
.pw-manifesto-item p { font-size: 13px; font-weight: 300; color: var(--pw-muted); line-height: 1.65; }

/* ── CTA BOX ──────────────────────────────────────── */
.pw-cta-box {
  background: var(--pw-bg3); border: 1px solid rgba(0,229,160,0.14);
  border-radius: 24px; padding: 80px 56px; text-align: center;
  position: relative; overflow: hidden; max-width: 1160px; margin: 0 auto;
}
.pw-cta-orb {
  position: absolute; top: -60px; left: 50%; transform: translateX(-50%);
  width: 500px; height: 280px; pointer-events: none;
  background: radial-gradient(ellipse, rgba(0,229,160,0.07) 0%, transparent 70%);
}
.pw-cta-box h2 { font-size: clamp(26px, 4vw, 50px); letter-spacing: -2px; margin-bottom: 12px; position: relative; }
.pw-cta-box > p { font-size: 16px; font-weight: 300; color: var(--pw-muted); margin-bottom: 32px; position: relative; }
.pw-cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; }

/* ── RESPONSIVE ───────────────────────────────────── */
@media (max-width: 960px) {
  .pw-product-hero { grid-template-columns: 1fr; }
  .pw-ph-right { display: none; }
  .pw-coming-grid { grid-template-columns: 1fr 1fr; }
  .pw-use-grid { grid-template-columns: 1fr 1fr; }
  .pw-about { grid-template-columns: 1fr; gap: 40px; }
  .pw-cta-box { padding: 56px 28px; }
}
@media (max-width: 580px) {
  .pw-hero h1 { letter-spacing: -2.5px; }
  .pw-hero-stats { gap: 28px; }
  .pw-coming-grid { grid-template-columns: 1fr; }
  .pw-use-grid { grid-template-columns: 1fr; }
}
</style>

<!-- HERO -->
