<style>
/* ── PRODUCT PAGE ─────────────────────────────────── */
.pw-product-page {
  max-width: 1160px; margin: 0 auto; padding: 0 5vw;
  padding-top: 48px; padding-bottom: 96px;
}
.pw-product-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
  margin-bottom: 80px;
}
/* Gallery */
.pw-gallery { position: sticky; top: 88px; }
.pw-gallery-main {
  background: var(--pw-bg3); border: 1px solid var(--pw-border);
  border-radius: var(--pw-radius-lg); overflow: hidden;
  aspect-ratio: 4/3; margin-bottom: 10px; position: relative;
}
.pw-gallery-main img {
  width: 100%; height: 100%; object-fit: contain; padding: 20px;
}
.pw-gallery-main .pw-gallery-placeholder {
  width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
  font-size: 64px;
}
.pw-gallery-thumbs { display: flex; gap: 8px; }
.pw-gallery-thumb {
  width: 72px; height: 72px; border-radius: 10px; overflow: hidden;
  border: 1px solid var(--pw-border); cursor: pointer;
  transition: border-color 0.2s; flex-shrink: 0;
  background: var(--pw-bg3); padding: 6px;
}
.pw-gallery-thumb img { width: 100%; height: 100%; object-fit: contain; }
.pw-gallery-thumb.active { border-color: var(--pw-green); }
.pw-gallery-thumb:hover { border-color: var(--pw-border2); }

/* Product info */
.pw-product-info {}
.pw-product-breadcrumb {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: var(--pw-muted2); margin-bottom: 16px;
  font-family: var(--pw-font-mono);
}
.pw-product-breadcrumb a { color: var(--pw-muted2); transition: color 0.2s; }
.pw-product-breadcrumb a:hover { color: var(--pw-green); }
.pw-product-breadcrumb span { color: var(--pw-muted2); }
.pw-product-title {
  font-family: var(--pw-font-display); font-size: clamp(28px, 4vw, 44px);
  font-weight: 800; letter-spacing: -1.5px; color: var(--pw-text);
  line-height: 1.05; margin-bottom: 14px;
}
.pw-product-desc-short {
  font-size: 15px; font-weight: 300; color: var(--pw-muted);
  line-height: 1.75; margin-bottom: 24px;
}
.pw-product-price-block {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 24px; padding: 20px 0;
  border-top: 1px solid var(--pw-border); border-bottom: 1px solid var(--pw-border);
}
.pw-product-price-block .pw-price-now { font-size: 42px; }
.pw-product-price-block .pw-price-old { font-size: 18px; }

/* Variants */
.pw-variants { margin-bottom: 24px; }
.pw-variants-label {
  font-size: 13px; color: var(--pw-muted); margin-bottom: 10px;
  font-family: var(--pw-font-mono); text-transform: uppercase; letter-spacing: 0.5px;
}
.pw-variants-options { display: flex; gap: 8px; flex-wrap: wrap; }
.pw-variant-btn {
  padding: 9px 20px; border-radius: 100px;
  border: 1px solid var(--pw-border2); color: var(--pw-muted);
  font-size: 13px; font-weight: 500; cursor: pointer;
  transition: all 0.2s; font-family: var(--pw-font-body);
}
.pw-variant-btn:hover { border-color: var(--pw-border2); color: var(--pw-text); }
.pw-variant-btn.active {
  border-color: var(--pw-green); color: var(--pw-green);
  background: var(--pw-green-dim);
}

/* Buy block */
.pw-buy-block { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.pw-btn-add-cart {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  background: var(--pw-green); color: #050807;
  font-weight: 700; font-size: 15px; padding: 15px 28px; border-radius: 100px;
  transition: transform 0.18s, box-shadow 0.18s;
  box-shadow: 0 0 28px var(--pw-green-glow);
  width: 100%; border: none; cursor: pointer;
  font-family: var(--pw-font-body);
}
.pw-btn-add-cart:hover {
  transform: translateY(-2px); box-shadow: 0 0 48px rgba(0,229,160,0.32);
}
.pw-btn-add-cart:disabled { opacity: 0.6; transform: none; cursor: not-allowed; }
.pw-btn-free-dl {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  border: 1px solid var(--pw-border2); color: var(--pw-muted);
  font-size: 14px; padding: 13px; border-radius: 100px;
  transition: border-color 0.2s, color 0.2s; width: 100%;
  font-family: var(--pw-font-body);
}
.pw-btn-free-dl:hover { border-color: var(--pw-green); color: var(--pw-green); }

/* Trust badges */
.pw-trust { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 24px; }
.pw-trust-item {
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  background: var(--pw-surface); border: 1px solid var(--pw-border);
  border-radius: 10px; padding: 12px 8px; text-align: center;
}
.pw-trust-icon { font-size: 20px; }
.pw-trust-text { font-size: 11px; color: var(--pw-muted); line-height: 1.3; font-weight: 300; }

/* Tags section */
.pw-tags-section { margin-bottom: 20px; }
.pw-tags-section h4 {
  font-family: var(--pw-font-mono); font-size: 11px; color: var(--pw-muted2);
  text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;
}
.pw-tags-cloud { display: flex; flex-wrap: wrap; gap: 6px; }

/* ── PRODUCT TABS (descripción / how-to / faq) ────── */
.pw-product-tabs { margin-bottom: 80px; }
.pw-tab-nav {
  display: flex; gap: 0; border-bottom: 1px solid var(--pw-border); margin-bottom: 40px;
}
.pw-tab-btn {
  font-family: var(--pw-font-body); font-size: 14px; font-weight: 500;
  color: var(--pw-muted); padding: 12px 24px; cursor: pointer;
  border: none; background: none;
  border-bottom: 2px solid transparent; margin-bottom: -1px;
  transition: color 0.2s, border-color 0.2s;
}
.pw-tab-btn:hover { color: var(--pw-text); }
.pw-tab-btn.pw-active { color: var(--pw-green); border-bottom-color: var(--pw-green); }
.pw-tab-panel { display: none; }
.pw-tab-panel.pw-active { display: block; }

/* Description content */
.pw-desc-content { max-width: 720px; }
.pw-desc-content p {
  font-size: 15px; font-weight: 300; color: var(--pw-muted);
  line-height: 1.8; margin-bottom: 16px;
}
.pw-desc-content h3 {
  font-family: var(--pw-font-display); font-size: 22px; font-weight: 700;
  color: var(--pw-text); letter-spacing: -0.5px; margin: 28px 0 12px;
}
.pw-desc-content ul { margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
.pw-desc-content li {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 14px; color: var(--pw-muted); font-weight: 300;
}
.pw-desc-content li::before {
  content: ''; flex-shrink: 0; width: 16px; height: 16px; margin-top: 2px;
  border-radius: 50%; background: var(--pw-green-dim) url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4L3.5 6.5L9 1' stroke='%2300E5A0' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center no-repeat;
  border: 1px solid rgba(0,229,160,0.2);
}

/* Steps how-to */
.pw-steps { display: flex; flex-direction: column; gap: 0; max-width: 680px; position: relative; }
.pw-steps::before {
  content: ''; position: absolute; left: 18px; top: 36px; bottom: 36px;
  width: 1px; background: linear-gradient(to bottom, var(--pw-green), transparent);
}
.pw-step-item { display: flex; gap: 20px; padding: 0 0 32px; position: relative; }
.pw-step-num-circle {
  width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
  background: var(--pw-surface); border: 1px solid var(--pw-border2);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--pw-font-mono); font-size: 13px; color: var(--pw-green);
  font-weight: 500; z-index: 1;
}
.pw-step-body h4 {
  font-family: var(--pw-font-display); font-size: 17px; font-weight: 700;
  color: var(--pw-text); letter-spacing: -0.3px; margin-bottom: 6px; padding-top: 6px;
}
.pw-step-body p { font-size: 14px; font-weight: 300; color: var(--pw-muted); line-height: 1.7; }
.pw-step-code {
  margin-top: 10px; background: var(--pw-surface); border: 1px solid var(--pw-border);
  border-radius: 8px; padding: 10px 14px;
  font-family: var(--pw-font-mono); font-size: 12px; color: var(--pw-muted); line-height: 1.8;
}
.pw-step-code .g { color: var(--pw-green); }

/* FAQ dentro del producto */
.pw-faq { max-width: 680px; }
.pw-faq-item { border-bottom: 1px solid var(--pw-border); }
.pw-faq-q {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 0; cursor: pointer; gap: 16px;
  font-size: 14px; font-weight: 600; color: var(--pw-text);
  background: none; border: none; width: 100%; text-align: left;
  font-family: var(--pw-font-body);
}
.pw-faq-q::after {
  content: '+'; font-size: 20px; font-weight: 300;
  color: var(--pw-green); flex-shrink: 0; transition: transform 0.3s;
}
.pw-faq-item.pw-open .pw-faq-q::after { transform: rotate(45deg); }
.pw-faq-a {
  font-size: 13px; font-weight: 300; color: var(--pw-muted);
  line-height: 1.8; max-height: 0; overflow: hidden;
  transition: max-height 0.35s ease, padding 0.3s;
}
.pw-faq-item.pw-open .pw-faq-a { max-height: 200px; padding-bottom: 16px; }

/* ── RELATED ──────────────────────────────────────── */
.pw-related h2 {
  font-family: var(--pw-font-display); font-size: 28px; font-weight: 800;
  letter-spacing: -1px; margin-bottom: 28px;
}

/* ── RESPONSIVE ───────────────────────────────────── */
@media (max-width: 900px) {
  .pw-product-grid { grid-template-columns: 1fr; gap: 36px; }
  .pw-gallery { position: static; }
  .pw-trust { grid-template-columns: repeat(3,1fr); }
}
@media (max-width: 480px) {
  .pw-trust { grid-template-columns: 1fr; }
  .pw-tab-btn { padding: 10px 14px; font-size: 13px; }
}
</style>

<div class="pw-product-page">

  <!-- Breadcrumb -->
  <div class="pw-product-breadcrumb">
    <a href="{{ routes.root_url }}">Inicio</a>
    <span>/</span>
    <a href="{{ routes.collections_url }}/all">Softwares</a>
    <span>/</span>
    <span>{{ product.title }}</span>
  </div>

  <div class="pw-product-grid">

    <!-- Gallery -->
    <div class="pw-gallery">
      <div class="pw-gallery-main" id="pw-gallery-main">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 800 }}"
               alt="{{ product.featured_image.alt | escape }}"
               id="pw-main-img">
        {%- else -%}
          <div class="pw-gallery-placeholder">📄</div>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="pw-gallery-thumbs">
          {%- for image in product.images limit: 6 -%}
            <div class="pw-gallery-thumb {% if forloop.first %}active{% endif %}"
                 data-src="{{ image | image_url: width: 800 }}"
                 data-alt="{{ image.alt | escape }}">
              <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="pw-product-info">

      <div class="pw-badge" style="margin-bottom:16px;">
        <span class="pw-badge-dot"></span>
        {%- if product.available -%}Disponible ahora{%- else -%}Agotado{%- endif -%}
      </div>

      <h1 class="pw-product-title">{{ product.title }}</h1>

      <p class="pw-product-desc-short">
        {%- if product.metafields.custom.short_description != blank -%}
          {{ product.metafields.custom.short_description }}
        {%- else -%}
          {{ product.description | strip_html | truncate: 180 }}
        {%- endif -%}
      </p>

      <!-- Price — se actualiza al cambiar variante -->
      <div class="pw-product-price-block" id="pw-price-block">
        <span class="pw-price-now" id="pw-price-now" style="font-size:42px;">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
        {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
          <span class="pw-price-old" id="pw-price-old" style="font-size:18px;">
            {{ product.selected_or_first_available_variant.compare_at_price | money }}
          </span>
          <span class="pw-price-off" id="pw-price-off">
            -{{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price | round }}%
          </span>
        {%- else -%}
          <span class="pw-price-old" id="pw-price-old" style="font-size:18px;display:none;"></span>
          <span class="pw-price-off" id="pw-price-off" style="display:none;"></span>
        {%- endif -%}
        <span id="pw-price-period" style="font-size:13px;color:var(--pw-muted);font-family:var(--pw-font-mono);margin-left:4px;">
          {%- if product.selected_or_first_available_variant.title contains 'Mensual' -%}/ mes
          {%- elsif product.selected_or_first_available_variant.title contains 'Anual' -%}/ año
          {%- endif -%}
        </span>
      </div>

      <!-- Form nativo Shopify -->
      {%- form 'product', product, id: 'pw-product-form', novalidate: 'novalidate' -%}

        {%- if product.variants.size > 1 -%}
          <div class="pw-variants">
            <div class="pw-variants-label">{{ product.options.first }}</div>
            <div class="pw-variants-options" id="pw-variant-options">
              {%- for variant in product.variants -%}
                <button type="button"
                        class="pw-variant-btn {% if forloop.first %}active{% endif %}"
                        data-variant-id="{{ variant.id }}"
                        data-available="{{ variant.available }}"
                        data-price="{{ variant.price | money }}"
                        data-compare="{{ variant.compare_at_price | money }}"
                        data-has-compare="{{ variant.compare_at_price > variant.price }}"
                        data-discount="{%- if variant.compare_at_price > variant.price -%}-{{ variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price | round }}%{%- endif -%}"
                        data-period="{%- if variant.title contains 'Mensual' -%}/ mes{%- elsif variant.title contains 'Anual' -%}/ año{%- endif -%}"
                        {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }}
                </button>
              {%- endfor -%}
            </div>
          </div>
          <input type="hidden" name="id" id="pw-variant-id" value="{{ product.selected_or_first_available_variant.id }}">
        {%- else -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {%- endif -%}

        <div class="pw-buy-block">
          <button type="button" id="pw-btn-checkout"
                  class="pw-btn-add-cart"
                  {%- unless product.available -%}disabled{%- endunless -%}>
            {%- if product.available -%}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M2 2h2l1.5 7h7.5l1.5-5.5H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="7" cy="13.5" r="1" fill="currentColor"/>
                <circle cx="12" cy="13.5" r="1" fill="currentColor"/>
              </svg>
              Comprar ahora
            {%- else -%}
              Sin stock
            {%- endif -%}
          </button>

          {%- if product.available -%}
            <button type="submit" name="add" id="pw-btn-cart"
                    class="pw-btn-free-dl"
                    style="border-color:rgba(0,229,160,0.3);color:var(--pw-green);">
              + Agregar al carrito
            </button>
          {%- endif -%}

          <a href="{{ routes.pages_url }}/descargas" class="pw-btn-free-dl">
            📥 Versión gratuita
          </a>
        </div>

      {%- endform -%}

      <script>
        (function(){
          var variantOptions = document.querySelectorAll('#pw-variant-options .pw-variant-btn');
          var hiddenInput    = document.getElementById('pw-variant-id');
          var checkoutBtn    = document.getElementById('pw-btn-checkout');
          var cartBtn        = document.getElementById('pw-btn-cart');
          var priceNow       = document.getElementById('pw-price-now');
          var priceOld       = document.getElementById('pw-price-old');
          var priceOff       = document.getElementById('pw-price-off');
          var pricePeriod    = document.getElementById('pw-price-period');

          /* ── Selección de variante → actualiza precio ── */
          variantOptions.forEach(function(btn) {
            btn.addEventListener('click', function() {
              variantOptions.forEach(function(b) { b.classList.remove('active'); });
              btn.classList.add('active');

              /* Actualizar hidden input */
              if (hiddenInput) hiddenInput.value = btn.getAttribute('data-variant-id');

              /* Actualizar precio */
              if (priceNow) priceNow.textContent = btn.getAttribute('data-price');
              if (pricePeriod) pricePeriod.textContent = btn.getAttribute('data-period');

              var hasCompare = btn.getAttribute('data-has-compare') === 'true';
              if (priceOld) {
                priceOld.textContent = hasCompare ? btn.getAttribute('data-compare') : '';
                priceOld.style.display = hasCompare ? '' : 'none';
              }
              if (priceOff) {
                priceOff.textContent = hasCompare ? btn.getAttribute('data-discount') : '';
                priceOff.style.display = hasCompare ? '' : 'none';
              }

              /* Actualizar botones si variante sin stock */
              var available = btn.getAttribute('data-available') === 'true';
              if (checkoutBtn) checkoutBtn.disabled = !available;
              if (cartBtn)     cartBtn.disabled     = !available;
            });
          });

          /* ── Comprar ahora → directo al checkout ── */
          if (checkoutBtn) {
            checkoutBtn.addEventListener('click', function() {
              var variantId = hiddenInput
                ? hiddenInput.value
                : '{{ product.selected_or_first_available_variant.id }}';

              checkoutBtn.disabled = true;
              checkoutBtn.textContent = 'Redirigiendo...';

              fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
              })
              .then(function() { window.location.href = '/checkout'; })
              .catch(function() {
                checkoutBtn.disabled = false;
                checkoutBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 2h2l1.5 7h7.5l1.5-5.5H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="13.5" r="1" fill="currentColor"/><circle cx="12" cy="13.5" r="1" fill="currentColor"/></svg> Comprar ahora';
              });
            });
          }
        })();
      </script>

      <!-- Trust -->
      <div class="pw-trust">
        <div class="pw-trust-item">
          <span class="pw-trust-icon">🔒</span>
          <span class="pw-trust-text">Pago seguro SSL</span>
        </div>
        <div class="pw-trust-item">
          <span class="pw-trust-icon">♾️</span>
          <span class="pw-trust-text">Suscripción renovable</span>
        </div>
        <div class="pw-trust-item">
          <span class="pw-trust-icon">🖥️</span>
          <span class="pw-trust-text">100% local sin internet</span>
        </div>
      </div>

      <!-- Tags -->
      {%- if product.tags.size > 0 -%}
        <div class="pw-tags-section">
          <h4>Tags compatibles</h4>
          <div class="pw-tags-cloud">
            {%- for tag in product.tags -%}
              <span class="pw-chip pw-chip-green">{{ tag }}</span>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>

  <!-- Tabs: Descripción / Cómo funciona / FAQ -->
  <div class="pw-product-tabs">
    <div class="pw-tabs">
      <div class="pw-tab-nav" role="tablist">
        <button class="pw-tab-btn pw-active" role="tab" aria-selected="true">Descripción</button>
        <button class="pw-tab-btn" role="tab" aria-selected="false">Cómo funciona</button>
        <button class="pw-tab-btn" role="tab" aria-selected="false">Preguntas frecuentes</button>
      </div>

      <!-- Tab 1: Descripción -->
      <div class="pw-tab-panel pw-active">
        <div class="pw-desc-content">
          {%- if product.description != blank -%}
            {{ product.description }}
          {%- else -%}
            <p>Olvídate de pasar horas redactando documentos uno a uno. El Generador de Documentos de PortalWow automatiza todo el proceso — crea cientos de documentos personalizados en segundos usando tu propia plantilla Word y un listado Excel.</p>
            <h3>¿Qué incluye?</h3>
            <ul>
              <li>Generación masiva ilimitada de documentos Word</li>
              <li>Compatible con cualquier plantilla .docx</li>
              <li>Sistema de tags personalizable (tú defines los campos)</li>
              <li>Lectura de Excel con filas ilimitadas</li>
              <li>Guardado automático con nombres personalizados</li>
              <li>Funciona 100% offline — sin internet, sin nube</li>
              <li>Actualizaciones incluidas</li>
            </ul>
            <h3>¿Para qué se usa?</h3>
            <p>Contratos laborales, finiquitos, contratos de arriendo, cotizaciones, certificados, cartas, diplomas, actas y cualquier documento que tengas que generar en masa con datos distintos.</p>
          {%- endif -%}
        </div>
      </div>

      <!-- Tab 2: Cómo funciona -->
      <div class="pw-tab-panel">
        <div class="pw-steps">
          <div class="pw-step-item">
            <div class="pw-step-num-circle">1</div>
            <div class="pw-step-body">
              <h4>Prepara tu plantilla Word</h4>
              <p>Abre tu documento Word y reemplaza los datos variables con tags entre dobles llaves. El nombre del tag será el encabezado de la columna en Excel.</p>
              <div class="pw-step-code">
                Estimado <span class="g">[nombre]</span>, el contrato N° <span class="g">[folio]</span><br>
                con <span class="g">[empresa]</span> RUT <span class="g">[rut]</span> tiene valor<br>
                de <span class="g">[monto]</span> pesos.
              </div>
            </div>
          </div>
          <div class="pw-step-item">
            <div class="pw-step-num-circle">2</div>
            <div class="pw-step-body">
              <h4>Carga tu Excel con los datos</h4>
              <p>Cada fila del Excel corresponde a una persona o documento. Los encabezados de columna deben coincidir exactamente con los tags de la plantilla.</p>
              <div class="pw-step-code">
                nombre | rut | empresa | folio | monto<br>
                <span class="g">Juan Pérez</span> | <span class="g">12.345.678-9</span> | Acme | 001 | 500.000<br>
                <span class="g">María López</span> | <span class="g">9.876.543-2</span> | Beta | 002 | 750.000
              </div>
            </div>
          </div>
          <div class="pw-step-item">
            <div class="pw-step-num-circle">3</div>
            <div class="pw-step-body">
              <h4>Elige la carpeta destino</h4>
              <p>Selecciona en qué carpeta de tu PC quieres guardar los documentos generados. Puedes definir el formato del nombre de cada archivo.</p>
            </div>
          </div>
          <div class="pw-step-item" style="padding-bottom:0;">
            <div class="pw-step-num-circle" style="background:var(--pw-green-dim);border-color:rgba(0,229,160,0.3);">⚡</div>
            <div class="pw-step-body">
              <h4>Genera y listo</h4>
              <p>Presiona generar. En segundos tendrás todos los documentos creados, nombrados automáticamente y guardados en tu carpeta.</p>
              <div class="pw-step-code" style="background:var(--pw-green-dim);border-color:rgba(0,229,160,0.2);">
                <span class="g">✓ 500 documentos generados</span><br>
                <span class="g">✓ Nombrados automáticamente</span><br>
                <span class="g">✓ Guardados en tu carpeta</span><br>
                <span class="g">✓ Completado en 8 segundos</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab 3: FAQ -->
      <div class="pw-tab-panel">
        <div class="pw-faq">
          <div class="pw-faq-item">
            <button class="pw-faq-q">¿Necesito saber programar?</button>
            <div class="pw-faq-a">No. Si sabes usar Word y Excel, ya sabes usar PortalWow. Solo escribes los tags entre dobles llaves en tu plantilla y listo.</div>
          </div>
          <div class="pw-faq-item">
            <button class="pw-faq-q">¿Cuántos documentos puedo generar?</button>
            <div class="pw-faq-a">Con la licencia de pago, sin límite. Puedes generar 1 o 100.000 documentos en un solo lote. La versión gratuita tiene un límite de 10 por lote.</div>
          </div>
          <div class="pw-faq-item">
            <button class="pw-faq-q">¿Mis datos se suben a algún servidor?</button>
            <div class="pw-faq-a">No. El software funciona 100% offline en tu computador. No necesita internet y no envía ningún dato a servidores externos.</div>
          </div>
          <div class="pw-faq-item">
            <button class="pw-faq-q">¿En qué sistema operativo funciona?</button>
            <div class="pw-faq-a">Actualmente en Windows. Si necesitas versión para Mac o Linux, escríbenos y lo evaluamos.</div>
          </div>
          <div class="pw-faq-item">
            <button class="pw-faq-q">¿Cómo funciona la suscripción?</button>
            <div class="pw-faq-a">El software funciona por suscripción mensual o anual. Mientras tu suscripción esté activa, tienes acceso completo y todas las actualizaciones incluidas. Puedes cancelar cuando quieras.</div>
          </div>
          <div class="pw-faq-item">
            <button class="pw-faq-q">¿Para qué tipos de documentos sirve?</button>
            <div class="pw-faq-a">Contratos, finiquitos, cotizaciones, certificados, cartas, informes, diplomas, actas y más. Cualquier documento Word con datos variables.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Productos relacionados -->
  {%- assign related = collections['all'].products | where: 'id', '!=', product.id | limit: 3 -%}
  {%- if related.size > 0 -%}
    <div class="pw-related">
      <h2>También te puede interesar</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
        {%- for rp in related -%}
          {% render 'product-card', product: rp %}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

<script>
(function(){
  // Gallery thumbs
  document.querySelectorAll('.pw-gallery-thumb').forEach(function(thumb){
    thumb.addEventListener('click', function(){
      document.querySelectorAll('.pw-gallery-thumb').forEach(function(t){ t.classList.remove('active'); });
      thumb.classList.add('active');
      var img = document.getElementById('pw-main-img');
      if(img){ img.src = thumb.getAttribute('data-src'); img.alt = thumb.getAttribute('data-alt'); }
    });
  });

  // Variant selection
  var selectedOptions = {};
  document.querySelectorAll('.pw-variant-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var pos = btn.getAttribute('data-option-position');
      document.querySelectorAll('[data-option-position="'+pos+'"]').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      selectedOptions[pos] = btn.getAttribute('data-value');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Product Main",
  "settings": [],
  "presets": [{ "name": "Product Main" }]
}
{% endschema %}
