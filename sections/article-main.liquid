<style>
.pw-article-page { max-width: 720px; margin: 0 auto; padding: 48px 5vw 96px; }
.pw-article-page-header { margin-bottom: 36px; padding-bottom: 28px; border-bottom: 1px solid var(--pw-border); }
.pw-article-page-meta { display:flex;align-items:center;gap:12px;margin-bottom:16px; }
.pw-article-page-title { font-size:clamp(26px,4vw,44px);letter-spacing: -0.3px;margin-bottom:0; }
.pw-article-page-img { border-radius:var(--pw-radius-lg);overflow:hidden;margin-bottom:32px; }
.pw-article-page-img img { width:100%;height:auto; }
.pw-article-page-body p { font-size:16px;font-weight:300;color:var(--pw-muted);line-height:1.85;margin-bottom:18px; }
.pw-article-page-body h2 { font-size:22px;letter-spacing:-0.5px;margin:32px 0 12px; }
.pw-article-page-body h3 { font-size:18px;margin:24px 0 8px; }
.pw-article-page-body ul { margin-bottom:18px;display:flex;flex-direction:column;gap:7px; }
.pw-article-page-body li { font-size:15px;color:var(--pw-muted);font-weight:300;padding-left:16px;position:relative; }
.pw-article-page-body li::before { content:'–';position:absolute;left:0;color:var(--pw-green); }
.pw-article-page-body code { font-family:var(--pw-font-mono);font-size:13px;background:var(--pw-surface);padding:2px 6px;border-radius:4px;color:var(--pw-green); }
.pw-article-back { display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--pw-muted);margin-bottom:28px;transition:color 0.2s; }
.pw-article-back:hover { color:var(--pw-green); }
</style>

<div class="pw-article-page">
  <a href="{{ blog.url }}" class="pw-article-back">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M12 7H2M6 3.5L2 7l4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Volver al blog
  </a>
  <div class="pw-article-page-header pw-reveal">
    <div class="pw-article-page-meta">
      {%- if article.tags.size > 0 -%}
        <span class="pw-badge" style="font-size:10px;padding:3px 10px;">{{ article.tags.first }}</span>
      {%- endif -%}
      <span style="font-family:var(--pw-font-mono);font-size:11px;color:var(--pw-muted2);">{{ article.published_at | date: '%d %B %Y' }}</span>
      <span style="font-family:var(--pw-font-mono);font-size:11px;color:var(--pw-muted2);">{{ article.author }}</span>
    </div>
    <h1 class="pw-article-page-title">{{ article.title }}</h1>
  </div>
  {%- if article.image -%}
    <div class="pw-article-page-img pw-reveal">
      <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}">
    </div>
  {%- endif -%}
  <div class="pw-article-page-body pw-reveal">{{ article.content }}</div>
</div>

{% schema %}
{ "name": "Article Main", "settings": [], "presets": [{ "name": "Article Main" }] }
{% endschema %}
