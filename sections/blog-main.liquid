<style>
.pw-blog-page { max-width: 1160px; margin: 0 auto; padding: 48px 5vw 96px; }
.pw-blog-header { text-align:center; margin-bottom: 56px; }
.pw-blog-header h1 { font-size: clamp(28px,4vw,48px); letter-spacing:-1.5px; margin-bottom:10px; }
.pw-blog-header p { font-size:16px; font-weight:300; color:var(--pw-muted); max-width:400px; margin:0 auto; }
.pw-blog-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }
.pw-article-card {
  background:var(--pw-bg3); border:1px solid var(--pw-border);
  border-radius:var(--pw-radius-lg); overflow:hidden;
  transition:border-color 0.25s, transform 0.25s;
  display:flex; flex-direction:column;
}
.pw-article-card:hover { border-color:rgba(0,229,160,0.22); transform:translateY(-4px); }
.pw-article-img { aspect-ratio:16/9; overflow:hidden; background:var(--pw-surface); }
.pw-article-img img { width:100%; height:100%; object-fit:cover; transition:transform 0.3s; }
.pw-article-card:hover .pw-article-img img { transform:scale(1.04); }
.pw-article-img-ph { width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:40px; }
.pw-article-body { padding:20px; flex:1; display:flex; flex-direction:column; gap:8px; }
.pw-article-meta { display:flex; align-items:center; gap:10px; }
.pw-article-tag { font-family:var(--pw-font-mono);font-size:10px;color:var(--pw-green);background:var(--pw-green-dim);border:1px solid rgba(0,229,160,0.2);padding:2px 8px;border-radius:100px; }
.pw-article-date { font-family:var(--pw-font-mono);font-size:10px;color:var(--pw-muted2); }
.pw-article-title { font-family:var(--pw-font-display);font-size:17px;font-weight:700;color:var(--pw-text);letter-spacing:-0.3px;line-height:1.3; }
.pw-article-excerpt { font-size:13px;font-weight:300;color:var(--pw-muted);line-height:1.65;flex:1; }
.pw-article-link { font-size:13px;color:var(--pw-green);display:inline-flex;align-items:center;gap:5px;margin-top:4px; }
@media(max-width:768px){ .pw-blog-grid{grid-template-columns:1fr 1fr;} }
@media(max-width:480px){ .pw-blog-grid{grid-template-columns:1fr;} }
</style>

<div class="pw-blog-page">
  <div class="pw-blog-header pw-reveal">
    <div class="pw-eyebrow" style="justify-content:center;">Blog</div>
    <h1>{{ blog.title }}</h1>
    <p>Novedades, tutoriales y actualizaciones de PortalWow.</p>
  </div>
  <div class="pw-blog-grid">
    {%- for article in blog.articles -%}
      <div class="pw-reveal" style="transition-delay:{{ forloop.index0 | times: 80 }}ms;">
        <a href="{{ article.url }}" class="pw-article-card">
          <div class="pw-article-img">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy">
            {%- else -%}
              <div class="pw-article-img-ph">📝</div>
            {%- endif -%}
          </div>
          <div class="pw-article-body">
            <div class="pw-article-meta">
              {%- if article.tags.size > 0 -%}
                <span class="pw-article-tag">{{ article.tags.first }}</span>
              {%- endif -%}
              <span class="pw-article-date">{{ article.published_at | date: '%d %b %Y' }}</span>
            </div>
            <div class="pw-article-title">{{ article.title }}</div>
            <p class="pw-article-excerpt">{{ article.excerpt | strip_html | truncate: 110 }}</p>
            <span class="pw-article-link">Leer más
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1.5 6h9M7 2.5l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </a>
      </div>
    {%- else -%}
      <div style="grid-column:span 3;text-align:center;padding:64px 0;color:var(--pw-muted);">
        <p style="font-size:40px;margin-bottom:16px;">📝</p>
        <p style="font-size:16px;font-weight:300;">Próximamente publicaremos el primer artículo.</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{ "name": "Blog Main", "settings": [], "presets": [{ "name": "Blog Main" }] }
{% endschema %}
