<div style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:5vw;position:relative;z-index:1;">
  <div style="font-family:var(--pw-font-display);font-size:120px;font-weight:800;letter-spacing:-6px;color:var(--pw-bg3);line-height:1;margin-bottom:24px;">404</div>
  <div class="pw-eyebrow" style="justify-content:center;margin-bottom:12px;">Página no encontrada</div>
  <h1 style="font-size:clamp(24px,3vw,36px);letter-spacing: -0.2px;margin-bottom:12px;">Esta página no existe.</h1>
  <p style="font-size:15px;font-weight:300;color:var(--pw-muted);max-width:360px;margin-bottom:28px;">El enlace que seguiste puede estar roto o la página fue eliminada.</p>
  <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
    <a href="{{ routes.root_url }}" class="pw-btn-primary">Ir al inicio</a>
    <a href="{{ routes.collections_url }}/all" class="pw-btn-secondary">Ver softwares</a>
  </div>
</div>

{% schema %}
{ "name": "Not Found", "settings": [], "presets": [{ "name": "Not Found" }] }
{% endschema %}
