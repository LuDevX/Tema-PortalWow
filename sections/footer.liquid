<style>
.pw-footer {
  border-top: 1px solid var(--pw-border);
  background: var(--pw-bg); position: relative; z-index: 1;
}
.pw-footer-top {
  padding: 60px 5vw 48px;
  display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 40px; max-width: 1160px; margin: 0 auto;
}
.pw-footer-brand img { height: 36px; margin-bottom: 14px; }
.pw-footer-brand-name {
  font-family: var(--pw-font-display); font-size: 18px; font-weight: 800;
  color: var(--pw-text); margin-bottom: 10px;
}
.pw-footer-brand p {
  font-size: 13px; font-weight: 300; color: var(--pw-muted);
  line-height: 1.7; max-width: 240px; margin-bottom: 20px;
}
.pw-footer-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--pw-green-dim); color: var(--pw-green);
  border: 1px solid rgba(0,229,160,0.2);
  font-family: var(--pw-font-mono); font-size: 10px;
  padding: 4px 10px; border-radius: 100px;
}
.pw-footer-col h4 {
  font-family: var(--pw-font-mono); font-size: 10px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1.5px;
  color: var(--pw-muted2); margin-bottom: 16px;
}
.pw-footer-col ul { display: flex; flex-direction: column; gap: 8px; }
.pw-footer-col a {
  font-size: 14px; color: var(--pw-muted); font-weight: 300;
  transition: color 0.2s;
}
.pw-footer-col a:hover { color: var(--pw-green); }
.pw-footer-bottom {
  border-top: 1px solid var(--pw-border);
  padding: 20px 5vw;
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 10px;
  max-width: 1160px; margin: 0 auto;
}
.pw-footer-copy {
  font-family: var(--pw-font-mono); font-size: 11px; color: var(--pw-muted2);
}
.pw-footer-copy span { color: var(--pw-green); }
.pw-footer-legal { display: flex; gap: 20px; }
.pw-footer-legal a { font-size: 12px; color: var(--pw-muted2); transition: color 0.2s; }
.pw-footer-legal a:hover { color: var(--pw-muted); }

@media (max-width: 768px) {
  .pw-footer-top { grid-template-columns: 1fr 1fr; gap: 28px; }
  .pw-footer-brand { grid-column: span 2; }
  .pw-footer-bottom { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 480px) {
  .pw-footer-top { grid-template-columns: 1fr; }
  .pw-footer-brand { grid-column: span 1; }
}
</style>

<footer class="pw-footer" role="contentinfo">
  <div class="pw-footer-top">
    <div class="pw-footer-brand">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: height: 80 }}" alt="{{ shop.name }}">
      {%- else -%}
        <div class="pw-footer-brand-name">{{ shop.name }}</div>
      {%- endif -%}
      <p>Software que automatiza, simplifica y resuelve. Herramientas digitales para profesionales y empresas en Chile.</p>
      <span class="pw-footer-badge">
        <span style="width:5px;height:5px;background:var(--pw-green);border-radius:50%;"></span>
        Hecho en Chile
      </span>
    </div>

    <div class="pw-footer-col">
      <h4>Softwares</h4>
      <ul>
        <li><a href="{{ routes.collections_url }}/all">Ver catálogo</a></li>
        <li><a href="/products/generador-de-documentos">Generador de Documentos</a></li>
        {%- if pages['descargas'].url != blank -%}
          <li><a href="/pages/descargas">Versión gratuita</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="pw-footer-col">
      <h4>Recursos</h4>
      <ul>
        {%- if pages['soporte'].url != blank -%}
          <li><a href="/pages/soporte">Centro de soporte</a></li>
        {%- endif -%}
        {%- if pages['blogs'].url != blank -%}
          <li><a href="/pages/blogs">Blog</a></li>
        {%- endif -%}
        {%- if pages['descargas'].url != blank -%}
          <li><a href="/pages/descargas">Descargas</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="pw-footer-col">
      <h4>Legal</h4>
      <ul>
        {%- if pages['politica-de-privacidad'].url != blank -%}
          <li><a href="/pages/politica-de-privacidad">Privacidad</a></li>
        {%- endif -%}
        {%- if pages['terminos-y-condiciones'].url != blank -%}
          <li><a href="/pages/terminos-y-condiciones">Términos</a></li>
        {%- endif -%}
        {%- if pages['politica-de-reembolso'].url != blank -%}
          <li><a href="/pages/politica-de-reembolso">Reembolsos</a></li>
        {%- endif -%}
      </ul>
    </div>
  </div>

  <div class="pw-footer-bottom">
    <p class="pw-footer-copy">© {{ 'now' | date: '%Y' }} <span>{{ shop.name }}</span> — Software que resuelve problemas reales.</p>
    <div class="pw-footer-legal">
      {%- if pages['politica-de-privacidad'].url != blank -%}
        <a href="/pages/politica-de-privacidad">Privacidad</a>
      {%- endif -%}
      {%- if pages['terminos-y-condiciones'].url != blank -%}
        <a href="/pages/terminos-y-condiciones">Términos</a>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
