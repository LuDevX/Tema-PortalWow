<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#080A0D">

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} — Software que resuelve problemas reales
    {%- elsif page_title -%}
      {{ page_title }} — {{ shop.name }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif template == 'index' -%}
    <meta name="description" content="PortalWow — Software que automatiza, simplifica y resuelve. Herramientas digitales para profesionales y empresas chilenas.">
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">
  {{ content_for_header }}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Syne:wght@700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}">

  <!-- Custom cursor -->
  <div id="pw-cursor"></div>
  <div id="pw-cursor-ring"></div>

  <!-- Grid background -->
  <div class="pw-grid-bg"></div>

  <!-- Nav overlay for mobile -->
  <div id="pw-nav-overlay" class="pw-nav-overlay"></div>

  {%- sections 'header-group' -%}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  <!-- Toast container -->
  <div id="pw-toasts" aria-live="polite"></div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
