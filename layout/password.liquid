<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Próximamente</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .pw-password-box {
      background: var(--pw-bg3); border: 1px solid var(--pw-border2);
      border-radius: 20px; padding: 48px 40px; text-align: center;
      max-width: 400px; width: 90%;
    }
    .pw-password-box h1 { font-size: 28px; letter-spacing: -1px; margin-bottom: 8px; }
    .pw-password-box p { color: var(--pw-muted); font-size: 14px; font-weight: 300; margin-bottom: 24px; }
    .pw-password-form { display: flex; flex-direction: column; gap: 10px; }
  </style>
</head>
<body>
  <div class="pw-grid-bg"></div>
  <div class="pw-password-box">
    <div class="pw-eyebrow" style="justify-content:center; margin-bottom:12px;">Acceso restringido</div>
    <h1>{{ shop.name }}</h1>
    <p>Esta tienda estará disponible pronto. Ingresa la contraseña para ver el contenido.</p>
    {% form 'storefront_password' %}
      <div class="pw-password-form">
        <input type="password" name="password" class="pw-input" placeholder="Contraseña" aria-label="Contraseña">
        <button type="submit" class="pw-btn-primary" style="justify-content:center;">Entrar</button>
      </div>
    {% endform %}
  </div>
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
